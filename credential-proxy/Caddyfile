:8080 {
	handle_path /anthropic/* {
		reverse_proxy https://api.anthropic.com {
			header_up x-api-key {env.ANTHROPIC_API_KEY}
			header_up Host api.anthropic.com
			header_down -Server
		}
	}

	handle_path /fastmail/* {
		reverse_proxy https://api.fastmail.com {
			header_up Authorization "Bearer {env.FASTMAIL_API_TOKEN}"
			header_up Host api.fastmail.com
			header_down -Server
		}
	}

	handle_path /groq/* {
		reverse_proxy https://api.groq.com {
			header_up Authorization "Bearer {env.GROQ_API_KEY}"
			header_up Host api.groq.com
			header_down -Server
		}
	}

	handle_path /brave/* {
		reverse_proxy https://api.search.brave.com {
			header_up X-Subscription-Token {env.BRAVE_API_KEY}
			header_up Host api.search.brave.com
			header_down -Server
		}
	}

	handle_path /local-llm/* {
		reverse_proxy {env.LOCAL_LLM_HOST} {
			header_up Authorization "Bearer {env.LOCAL_LLM_API_KEY}"
			header_down -Server
		}
	}

	handle_path /gmail/* {
		reverse_proxy localhost:8081 {
			transport http {
				read_timeout 300s
				write_timeout 300s
				dial_timeout 10s
			}
		}
	}

}
