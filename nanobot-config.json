{
    "agents": {
        "defaults": {
            "workspace": "/data/nanobot/workspace",
            "model": "anthropic/claude-haiku-4-5-20251001",
            "maxTokens": 4096,
            "temperature": 0.7,
            "maxToolIterations": 10,
            "memoryWindow": 20
        }
    },
    "providers": {
        "anthropic": {}
    },
    "channels": {
        "sendToolHints": true
    },
    "tools": {
        "restrictToWorkspace": true,
        "exec": {
            "timeout": 120
        },
        "mcpServers": {
            "brave": {
                "command": ".venv/bin/python",
                "args": ["-m", "personal_agent.brave.tools"],
                "env": {}
            },
            "email": {
                "command": ".venv/bin/python",
                "args": ["-m", "personal_agent.email.tools"],
                "env": {},
                "toolTimeout": 120
            },
            "scratchpad": {
                "command": ".venv/bin/python",
                "args": ["-m", "personal_agent.scratchpad"],
                "env": {}
            }
        }
    },
    "gateway": {
        "host": "0.0.0.0",
        "port": 18790
    }
}
